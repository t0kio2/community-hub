<!DOCTYPE html>
  <html>
    <head>
      <meta charset="utf-8">
      <meta name="viewport" content="width=device-width, initial-scale=1">
      <title>Tenant Dashboard</title>
      <style>
        body { font-family: system-ui, -apple-system, sans-serif; margin: 40px; }
        .box { max-width: 680px; margin: 0 auto; padding: 24px; border: 1px solid #ddd; border-radius: 8px; }
        h1 { margin-top: 0; }
        .flash { margin-bottom: 12px; }
        .flash.notice { background:#e7f6ec;border:1px solid #b7e1c0;color:#0a4; padding:10px; border-radius:6px; }
        .flash.alert  { background:#fff3f3;border:1px solid #f5c2c2;color:#900; padding:10px; border-radius:6px; }
        .actions { margin-top: 16px; }
      </style>
    </head>
    <body>
      <div class="box">
        <h1>テナントダッシュボード</h1>
        <% if flash[:notice] %>
          <div class="flash notice"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert] %>
          <div class="flash alert"><%= flash[:alert] %></div>
        <% end %>
        <p>ログイン中: <strong><%= current_tenant_account.email %></strong></p>

        <div class="actions">
          <form action="<%= destroy_tenant_account_session_path %>" method="post" style="display:inline-block;">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>" />
            <button type="submit">ログアウト</button>
          </form>
        </div>
      </div>
    </body>
  </html>