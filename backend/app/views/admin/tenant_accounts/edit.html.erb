<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Edit Tenant Account</title>
    <style>
      body { font-family: system-ui, -apple-system, sans-serif; margin: 40px; }
      .box { max-width: 520px; margin: 0 auto; padding: 24px; border: 1px solid #ddd; border-radius: 8px; }
      label { display:block; margin:10px 0 6px; }
      input[type="email"], input[type="password"] { width:100%; padding:10px; box-sizing:border-box; }
      button { margin-top:16px; padding:10px 16px; }
      .errors { background:#fff3f3; color:#900; padding:10px; margin-bottom:12px; border:1px solid #f5c2c2; border-radius:6px; }
      .nav { margin-bottom: 16px; }
      .nav a { color: #0366d6; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="box">
      <div class="nav">
        <a href="<%= admin_tenant_accounts_path %>">← テナント一覧へ戻る</a>
      </div>
      <h1>テナントアカウント編集</h1>

      <% if @tenant.errors.any? %>
        <div class="errors">
          <p>エラーが発生しました:</p>
          <ul>
            <% @tenant.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @tenant, url: admin_tenant_account_path(@tenant), method: :patch, local: true do |f| %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

        <label for="tenant_email">Email</label>
        <%= f.email_field :email, id: 'tenant_email', required: true, autocomplete: 'username' %>

        <p style="margin-top:10px; color:#555;">パスワード未入力の場合は変更されません。</p>

        <label for="tenant_password">Password</label>
        <%= f.password_field :password, id: 'tenant_password', autocomplete: 'new-password' %>

        <label for="tenant_password_confirmation">Password confirmation</label>
        <%= f.password_field :password_confirmation, id: 'tenant_password_confirmation', autocomplete: 'new-password' %>

        <button type="submit">更新する</button>
      <% end %>
    </div>
  </body>
  </html>

