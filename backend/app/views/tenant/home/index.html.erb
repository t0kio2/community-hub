<% content_for :title, 'Tenant Home' %>

<div class="tenant-home">
  <section class="tenant-overview" aria-labelledby="tenant-home-title">
    <div>
      <p class="tenant-label">組織情報</p>
      <h1 id="tenant-home-title">
        <%= current_tenant_organization&.name.presence || 'テナントホーム' %>
      </h1>
      <% if current_tenant_organization&.kana.present? %>
        <p class="tenant-kana"><%= current_tenant_organization.kana %></p>
      <% end %>
    </div>

    <% if current_tenant_organization %>
      <div class="tenant-overview-actions">
        <span class="tenant-status"><%= current_tenant_organization.status.presence || '-' %></span>
        <% if current_tenant_member&.role == 'owner' %>
          <a class="tenant-edit-link" href="<%= edit_tenant_organization_path %>">組織情報を編集</a>
        <% end %>
      </div>
    <% end %>
  </section>

  <% if current_tenant_organization %>
    <section class="tenant-summary" aria-label="組織情報">
      <div class="tenant-summary-item">
        <span>Account</span>
        <strong><%= current_tenant_account.email %></strong>
      </div>
      <div class="tenant-summary-item">
        <span>Role</span>
        <strong><%= current_tenant_member.role.presence || '-' %></strong>
      </div>
      <div class="tenant-summary-item">
        <span>Address</span>
        <strong><%= current_tenant_organization.address.presence || '-' %></strong>
      </div>
    </section>

  <% else %>
    <section class="tenant-empty" aria-label="組織情報なし">
      <h2>組織情報がありません</h2>
      <p>このアカウントに紐づく tenant 組織情報がないため、管理メニューを表示できません。</p>
    </section>
  <% end %>
</div>

<style>
  .tenant-home {
    display: grid;
    gap: 24px;
  }

  .tenant-overview {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid #d8dee8;
    padding-bottom: 20px;
  }

  .tenant-label {
    margin: 0 0 6px;
    color: #64748b;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .tenant-overview h1 {
    margin: 0;
    color: #111827;
    font-size: 30px;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }

  .tenant-kana {
    margin: 8px 0 0;
    color: #475569;
    font-size: 14px;
  }

  .tenant-status {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border: 1px solid #86efac;
    border-radius: 999px;
    background: #f0fdf4;
    color: #166534;
    font-size: 13px;
    font-weight: 700;
    white-space: nowrap;
  }

  .tenant-overview-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .tenant-edit-link {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 14px;
    border: 1px solid #2563eb;
    border-radius: 8px;
    background: #2563eb;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .tenant-edit-link:hover {
    text-decoration: none;
    background: #1d4ed8;
  }

  .tenant-summary {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    overflow: hidden;
    border: 1px solid #d8dee8;
    border-radius: 8px;
    background: #d8dee8;
  }

  .tenant-summary-item {
    min-width: 0;
    background: #fff;
    padding: 16px;
  }

  .tenant-summary-item span {
    display: block;
    margin-bottom: 6px;
    color: #64748b;
    font-size: 12px;
    font-weight: 700;
  }

  .tenant-summary-item strong {
    display: block;
    color: #111827;
    font-size: 15px;
    line-height: 1.45;
    overflow-wrap: anywhere;
  }

  .tenant-empty h2 {
    margin: 0;
    color: #111827;
    font-size: 20px;
    line-height: 1.3;
  }

  .tenant-empty p {
    margin: 6px 0 0;
    color: #4b5563;
  }

  .tenant-empty {
    border: 1px solid #facc15;
    border-radius: 8px;
    background: #fffbeb;
    padding: 16px;
  }

  @media (max-width: 820px) {
    .tenant-overview {
      display: grid;
    }

    .tenant-summary {
      grid-template-columns: 1fr;
    }

    .tenant-overview-actions {
      justify-content: flex-start;
    }
  }
</style>
