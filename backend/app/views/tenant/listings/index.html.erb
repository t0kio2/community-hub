<% content_for :title, "掲載管理" %>

<div class="listing-page">
  <section class="listing-page-header" aria-labelledby="tenant-listings-title">
    <div>
      <p class="listing-label">掲載管理</p>
      <h1 id="tenant-listings-title">掲載一覧</h1>
    </div>
    <div class="header-actions">
      <a class="primary-action" href="<%= new_tenant_listing_path(listing_type: "job") %>">求人作成</a>
      <a class="secondary-action" href="<%= new_tenant_listing_path(listing_type: "stay") %>">宿泊作成</a>
    </div>
  </section>

  <% if @listings.any? %>
    <table class="listing-table">
      <thead>
        <tr>
          <th>タイトル</th>
          <th>種別</th>
          <th>ステータス</th>
          <th>更新日</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @listings.each do |listing| %>
          <tr>
            <td><strong><%= listing.title %></strong></td>
            <td><%= listing.listing_type %></td>
            <td><span class="status-badge"><%= listing.status %></span></td>
            <td><%= l(listing.updated_at, format: :short) %></td>
            <td class="listing-actions">
              <a href="<%= tenant_listing_path(listing) %>">詳細</a>
              <a href="<%= edit_tenant_listing_path(listing) %>">編集</a>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <section class="empty-state" aria-label="掲載なし">
      <h2>掲載がありません</h2>
    </section>
  <% end %>
</div>

<style>
  .listing-page {
    display: grid;
    gap: 20px;
  }

  .listing-page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid #d8dee8;
    padding-bottom: 18px;
  }

  .listing-label {
    margin: 0 0 6px;
    color: #64748b;
    font-size: 13px;
    font-weight: 700;
  }

  .listing-page h1 {
    margin: 0;
    color: #111827;
    font-size: 28px;
    line-height: 1.25;
  }

  .primary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid #2563eb;
    border-radius: 8px;
    background: #2563eb;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .secondary-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 14px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    background: #fff;
    color: #334155;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .listing-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #d8dee8;
  }

  .listing-table th,
  .listing-table td {
    border-bottom: 1px solid #e5e7eb;
    padding: 12px;
    text-align: left;
    vertical-align: top;
  }

  .listing-table th {
    background: #f8fafc;
    color: #475569;
    font-size: 13px;
  }

  .listing-table td {
    color: #111827;
    font-size: 14px;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    min-height: 26px;
    padding: 0 10px;
    border: 1px solid #cbd5e1;
    border-radius: 999px;
    background: #f8fafc;
    color: #334155;
    font-size: 12px;
    font-weight: 700;
  }

  .listing-actions {
    display: flex;
    gap: 12px;
    white-space: nowrap;
  }

  .listing-actions a {
    color: #2563eb;
    font-weight: 700;
    text-decoration: none;
  }

  .empty-state {
    border: 1px solid #d8dee8;
    border-radius: 8px;
    padding: 16px;
  }

  .empty-state h2 {
    margin: 0;
    color: #111827;
    font-size: 18px;
  }

  @media (max-width: 760px) {
    .listing-page-header {
      display: grid;
    }

    .listing-table {
      display: block;
      overflow-x: auto;
    }
  }
</style>
