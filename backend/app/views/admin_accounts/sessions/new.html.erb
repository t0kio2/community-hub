<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin Sign In</title>
    <style>
      body { font-family: system-ui, -apple-system, sans-serif; margin: 40px; }
      .box { max-width: 420px; margin: 0 auto; padding: 24px; border: 1px solid #ddd; border-radius: 8px; }
      label { display:block; margin:10px 0 6px; }
      input[type="email"], input[type="password"] { width:100%; padding:10px; box-sizing:border-box; }
      button { margin-top:16px; padding:10px 16px; }
      .flash { margin-bottom: 12px; }
      .flash.notice { background:#e7f6ec;border:1px solid #b7e1c0;color:#0a4; padding:10px; border-radius:6px; }
      .flash.alert  { background:#fff3f3;border:1px solid #f5c2c2;color:#900; padding:10px; border-radius:6px; }
      .nav { margin-bottom: 16px; }
      .nav a { color: #0366d6; text-decoration: none; }
    </style>
  </head>
  <body>
    <div class="box">
      <h1>Admin ログイン</h1>

      <% if flash[:notice].present? %>
        <div class="flash notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert].present? %>
        <div class="flash alert"><%= flash[:alert] %></div>
      <% end %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

        <label for="admin_email">Email</label>
        <%= f.email_field :email, id: 'admin_email', required: true, autocomplete: 'username' %>

        <label for="admin_password">Password</label>
        <%= f.password_field :password, id: 'admin_password', required: true, autocomplete: 'current-password' %>

        <div style="margin-top:8px;">
          <label style="display: inline-flex; align-items: center; gap: 6px;">
            <%= f.check_box :remember_me %>
            <span>ログイン状態を保持</span>
          </label>
        </div>

        <button type="submit">Log in</button>
      <% end %>
    </div>
  </body>
</html>

